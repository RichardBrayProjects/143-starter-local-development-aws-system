{
  "name": "starter-system",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "local:start": "pnpm -C scripts local:start",
    "local:stop": "pnpm -C scripts local:stop",
    "dev:server": "pnpm -C services/core dev",
    "dev:web": "pnpm -C apps/ui dev",
    "build": "pnpm -C apps/ui build",
    "db:migrate": "pnpm -C services/core db:migrate",
    "bootstrap-up": "pnpm -C scripts bootstrap-up",
    "deploy": "pnpm -C scripts deploy",
    "destroy": "pnpm -C scripts destroy",
    "url": "pnpm -C scripts url",
    "package-clean": "pnpm run package-cleanup",
    "package-cleanup": "pnpm -r package-cleanup && rm -rf node_modules"
  },
  "devDependencies": {
    "esbuild": "0.27.7"
  }
}
